{
  "name": "opencode-insights",
  "version": "2026.3.26",
  "files": [
    "dist",
    ".opencode",
    "README.md"
  ],
  "description": "opencode plugin: generate insights reports from your session history",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=esnext --format=esm --external:bun:sqlite --external:bun --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "esbuild": "^0.25.0",
    "playwright": "^1.58.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "opencode",
    "plugin",
    "insights",
    "analytics"
  ],
  "license": "MIT"
}
